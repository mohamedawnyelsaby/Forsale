{
  "name": "forsale",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered global marketplace on Pi Network",
  "author": "Forsale Team",
  "license": "PROPRIETARY",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "turbo run dev --filter=@forsale/api",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@forsale/api",
    "start:api": "node services/api/dist/index.js",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @forsale/database prisma generate",
    "db:push": "pnpm --filter @forsale/database prisma db push",
    "db:studio": "pnpm --filter @forsale/database prisma studio"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
